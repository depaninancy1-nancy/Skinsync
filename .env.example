# ============================================
# SKINSYNC - ENVIRONMENT VARIABLES
# ============================================

# Flask Configuration
FLASK_ENV=development
FLASK_APP=backend/app.py
DEBUG=True
SECRET_KEY=your-secret-key-here-change-in-production

# Database Configuration
# For MySQL
DATABASE_URL=mysql+pymysql://root:password@localhost:3306/skinsync

# For Oracle (uncomment to use)
# DATABASE_URL=oracle://username:password@localhost:1521/skinsync

# JWT Configuration
JWT_SECRET_KEY=your-jwt-secret-key-here

# CORS Configuration
CORS_ORIGINS=http://localhost:5000,http://localhost:3000,http://127.0.0.1:5000

# Email Configuration (for contact form, etc.)
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=True
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-app-password

# File Upload Configuration
MAX_CONTENT_LENGTH=16777216
